#!/usr/bin/env bash
#
# Trigger release builds on GitHub Actions and publish as a GitHub Release.
#
# Usage:
#   ./scripts/release                Trigger CI builds
#   ./scripts/release --publish      Auto-increment patch version and publish
#   ./scripts/release --publish minor Increment minor version (x.Y.0) and publish
#   ./scripts/release --publish major Increment major version (X.0.0) and publish
#
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONF="$PROJECT_ROOT/src-tauri/tauri.conf.json"
REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)

if [ -z "$REPO" ]; then
    echo "ERROR: Could not determine GitHub repository."
    echo "Make sure you're in a git repo with a GitHub remote and 'gh' is authenticated."
    exit 1
fi

if ! command -v gh &>/dev/null; then
    echo "ERROR: GitHub CLI (gh) is required."
    echo "Install: brew install gh"
    exit 1
fi

read_version() {
    grep '"version"' "$CONF" | head -1 | sed 's/.*: *"\(.*\)".*/\1/'
}

bump_version() {
    local current="$1" bump="${2:-patch}"
    local major minor patch
    IFS='.' read -r major minor patch <<< "$current"

    case "$bump" in
        major) major=$((major + 1)); minor=0; patch=0 ;;
        minor) minor=$((minor + 1)); patch=0 ;;
        *)     patch=$((patch + 1)) ;;
    esac

    echo "${major}.${minor}.${patch}"
}

set_version() {
    local new_version="$1"
    sed -i '' "s/\"version\": *\"[^\"]*\"/\"version\": \"${new_version}\"/" "$CONF"
}

if [ "${1:-}" = "--publish" ]; then
    BUMP_TYPE="${2:-patch}"

    RUN_ID=$(gh run list --workflow=release.yml --status=success --limit=1 --json databaseId -q '.[0].databaseId')
    if [ -z "$RUN_ID" ]; then
        echo "ERROR: No successful build found."
        echo "Run './scripts/release' first to trigger a build."
        exit 1
    fi

    OLD_VERSION=$(read_version)
    NEW_VERSION=$(bump_version "$OLD_VERSION" "$BUMP_TYPE")
    TAG="v${NEW_VERSION}"

    if git -C "$PROJECT_ROOT" rev-parse "$TAG" &>/dev/null; then
        echo "ERROR: Tag ${TAG} already exists. Version ${NEW_VERSION} has already been released."
        echo "Current version in tauri.conf.json: ${OLD_VERSION}"
        exit 1
    fi

    echo "=== Publishing SQLCipherUI ${TAG} ==="
    echo "  Version bump: ${OLD_VERSION} → ${NEW_VERSION} (${BUMP_TYPE})"
    echo "  Build run: ${RUN_ID}"
    echo ""

    set_version "$NEW_VERSION"
    git -C "$PROJECT_ROOT" add "$CONF"
    git -C "$PROJECT_ROOT" commit -m "release ${TAG}"
    git -C "$PROJECT_ROOT" push origin main

    git -C "$PROJECT_ROOT" tag "$TAG"
    git -C "$PROJECT_ROOT" push origin "$TAG"

    echo ""
    echo "Tag ${TAG} pushed — publish workflow triggered."
    echo "Monitor progress:"
    echo "  gh run list --workflow=publish.yml"
    echo "  gh run watch"
else
    VERSION=$(read_version)
    TAG="v${VERSION}"

    echo "=== SQLCipherUI Release Builder (current: ${TAG}) ==="
    echo ""
    echo "Triggering CI builds for macOS and Windows..."

    gh workflow run release.yml --field version="$VERSION"

    echo ""
    echo "Build triggered. Monitor progress:"
    echo "  gh run list --workflow=release.yml"
    echo "  gh run watch"
    echo ""
    echo "Once complete, publish a release:"
    echo "  ./scripts/release --publish          (${VERSION} → $(bump_version "$VERSION" patch))"
    echo "  ./scripts/release --publish minor    (${VERSION} → $(bump_version "$VERSION" minor))"
    echo "  ./scripts/release --publish major    (${VERSION} → $(bump_version "$VERSION" major))"
fi
