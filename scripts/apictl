#!/usr/bin/env bash
# API Server Control Script

set -e

# Configuration
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$PROJECT_ROOT/.run/api.pid"
LOG_FILE="$PROJECT_ROOT/logs/api.log"
VENV_DIR="$PROJECT_ROOT/.venv"

# Ensure directories exist
mkdir -p "$PROJECT_ROOT/.run" "$PROJECT_ROOT/logs"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
print_error() {
    echo -e "${RED}Error: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

print_warning() {
    echo -e "${YELLOW}$1${NC}"
}

check_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        print_error "Virtual environment not found at $VENV_DIR"
        echo "Please create it with: python -m venv .venv && source .venv/bin/activate && pip install -e packages/core -e 'packages/api[dev]'"
        exit 1
    fi
}

is_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            return 0
        else
            # PID file exists but process is not running
            rm -f "$PID_FILE"
            return 1
        fi
    fi
    return 1
}

start_api() {
    if is_running; then
        print_warning "API server is already running (PID: $(cat "$PID_FILE"))"
        exit 0
    fi

    check_venv

    print_success "Starting API server..."
    cd "$PROJECT_ROOT"

    # Start uvicorn in the background (localhost only for security)
    "$VENV_DIR/bin/uvicorn" sqlcipherui_api.main:app \
        --reload \
        --reload-dir packages/api/src \
        --reload-dir packages/core/src \
        --host 127.0.0.1 \
        --port 8001 \
        >> "$LOG_FILE" 2>&1 &

    echo $! > "$PID_FILE"

    # Wait a moment and check if it started successfully
    sleep 2
    if is_running; then
        print_success "API server started successfully (PID: $(cat "$PID_FILE"))"
        print_success "API available at: http://localhost:8001"
        print_success "API docs at: http://localhost:8001/docs"
        print_success "Logs: $LOG_FILE"
    else
        print_error "Failed to start API server. Check logs: $LOG_FILE"
        exit 1
    fi
}

stop_api() {
    if ! is_running; then
        print_warning "API server is not running"
        return 0
    fi

    PID=$(cat "$PID_FILE")
    print_success "Stopping API server (PID: $PID)..."

    kill "$PID" 2>/dev/null || true

    # Wait for process to stop
    for i in {1..10}; do
        if ! ps -p "$PID" > /dev/null 2>&1; then
            rm -f "$PID_FILE"
            print_success "API server stopped"
            return 0
        fi
        sleep 0.5
    done

    # Force kill if still running
    print_warning "Process did not stop gracefully, forcing..."
    kill -9 "$PID" 2>/dev/null || true
    rm -f "$PID_FILE"
    print_success "API server stopped"
}

restart_api() {
    stop_api
    sleep 1
    start_api
}

status_api() {
    if is_running; then
        PID=$(cat "$PID_FILE")
        print_success "API server is running (PID: $PID)"
        print_success "API available at: http://localhost:8001"
        print_success "API docs at: http://localhost:8001/docs"
        exit 0
    else
        print_warning "API server is not running"
        exit 1
    fi
}

show_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        print_warning "No log file found at $LOG_FILE"
        exit 1
    fi

    if [ "$1" = "-f" ] || [ "$1" = "--follow" ]; then
        tail -f "$LOG_FILE"
    else
        tail -n 50 "$LOG_FILE"
    fi
}

# Main command handling
case "$1" in
    start)
        start_api
        ;;
    stop)
        stop_api
        ;;
    restart)
        restart_api
        ;;
    status)
        status_api
        ;;
    logs)
        show_logs "$2"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|logs [-f]}"
        echo ""
        echo "Commands:"
        echo "  start    - Start the API server"
        echo "  stop     - Stop the API server"
        echo "  restart  - Restart the API server"
        echo "  status   - Check if the API server is running"
        echo "  logs     - Show recent logs (use -f to follow)"
        exit 1
        ;;
esac
