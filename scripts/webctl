#!/usr/bin/env bash
# Web Dev Server Control Script

set -e

# Configuration
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$PROJECT_ROOT/.run/web.pid"
LOG_FILE="$PROJECT_ROOT/logs/web.log"
WEB_DIR="$PROJECT_ROOT/packages/web"

# Ensure directories exist
mkdir -p "$PROJECT_ROOT/.run" "$PROJECT_ROOT/logs"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
print_error() {
    echo -e "${RED}Error: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

print_warning() {
    echo -e "${YELLOW}$1${NC}"
}

check_node_modules() {
    if [ ! -d "$WEB_DIR/node_modules" ]; then
        print_error "node_modules not found in $WEB_DIR"
        echo "Please install dependencies with: npm --prefix packages/web install"
        exit 1
    fi
}

is_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            return 0
        else
            # PID file exists but process is not running
            rm -f "$PID_FILE"
            return 1
        fi
    fi
    return 1
}

start_web() {
    if is_running; then
        print_warning "Web dev server is already running (PID: $(cat "$PID_FILE"))"
        return 0
    fi

    check_node_modules

    print_success "Starting web dev server..."
    cd "$PROJECT_ROOT"

    # Start vite dev server in the background
    npm --prefix packages/web run dev >> "$LOG_FILE" 2>&1 &

    echo $! > "$PID_FILE"

    # Wait a moment and check if it started successfully
    sleep 2
    if is_running; then
        print_success "Web dev server started successfully (PID: $(cat "$PID_FILE"))"
        print_success "Web app available at: http://localhost:5273"
        print_success "Logs: $LOG_FILE"
    else
        print_error "Failed to start web dev server. Check logs: $LOG_FILE"
        return 1
    fi
}

stop_web() {
    if ! is_running; then
        print_warning "Web dev server is not running"
        return 0
    fi

    PID=$(cat "$PID_FILE")
    print_success "Stopping web dev server (PID: $PID)..."

    # Kill the process group to ensure vite and all child processes are killed
    kill -- -"$PID" 2>/dev/null || kill "$PID" 2>/dev/null || true

    # Wait for process to stop
    for i in {1..10}; do
        if ! ps -p "$PID" > /dev/null 2>&1; then
            rm -f "$PID_FILE"
            print_success "Web dev server stopped"
            return 0
        fi
        sleep 0.5
    done

    # Force kill if still running
    print_warning "Process did not stop gracefully, forcing..."
    kill -9 -- -"$PID" 2>/dev/null || kill -9 "$PID" 2>/dev/null || true
    rm -f "$PID_FILE"
    print_success "Web dev server stopped"
}

restart_web() {
    stop_web
    sleep 1
    start_web
}

status_web() {
    if is_running; then
        PID=$(cat "$PID_FILE")
        print_success "Web dev server is running (PID: $PID)"
        print_success "Web app available at: http://localhost:5273"
        exit 0
    else
        print_warning "Web dev server is not running"
        exit 1
    fi
}

show_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        print_warning "No log file found at $LOG_FILE"
        exit 1
    fi

    if [ "$1" = "-f" ] || [ "$1" = "--follow" ]; then
        tail -f "$LOG_FILE"
    else
        tail -n 50 "$LOG_FILE"
    fi
}

# Main command handling
case "$1" in
    start)
        start_web
        ;;
    stop)
        stop_web
        ;;
    restart)
        restart_web
        ;;
    status)
        status_web
        ;;
    logs)
        show_logs "$2"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|logs [-f]}"
        echo ""
        echo "Commands:"
        echo "  start    - Start the web dev server"
        echo "  stop     - Stop the web dev server"
        echo "  restart  - Restart the web dev server"
        echo "  status   - Check if the web dev server is running"
        echo "  logs     - Show recent logs (use -f to follow)"
        exit 1
        ;;
esac
